# Root .env example for deployment
# COPY this file to .env and edit values before running deploy/bootstrap-ec2.sh

# OpenAI or GitHub token (used by agent for API or fallbacks)
OPENAI_API_KEY=
GITHUB_TOKEN=

# SITE_ADDRESS should be set to the HTTPS address where the site will be reachable
# For AWS Academy EC2 lab you can set it to your public IP with https://<IP>
SITE_ADDRESS=

# Optional: thresholds for alerts
P95_THRESHOLD_S=2.0
ERROR_RATE_THRESHOLD=0.05
ALERT_CHECK_INTERVAL_S=60
