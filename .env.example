# ========================================================================
# Configuración de OpenAI API
# ========================================================================

# Tu clave API de OpenAI (requerida)
# Obtén la tuya en: https://platform.openai.com/api-keys
OPENAI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========================================================================
# Configuración de Email (Opcional)
# ========================================================================

# Si deseas que el agente envíe correos de verdad (opcional)
# Por defecto, guarda archivos .eml localmente
SENDER_EMAIL=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDER_PASSWORD=xxxxxxxxxxxxxxxxxxxxxx

# Nota: Para Gmail, usa una "Contraseña de Aplicación" generada en:
# https://myaccount.google.com/apppasswords

# ========================================================================
# Configuración de Entorno
# ========================================================================

# Entorno: development, staging, production
ENVIRONMENT=development

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
