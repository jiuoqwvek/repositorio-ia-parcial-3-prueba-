# --- GitHub Models (mismo proveedor que el resto del curso) ---
# GitHub token usado para acceder a modelos o recursos privados (si aplica)
GITHUB_TOKEN=""
OPENAI_BASE_URL="https://models.inference.ai.azure.com"
AGENT_MODEL="gpt-4o-mini"

# --- Observabilidad (opcional, reusa RA3.1/3.2) ---
LANGSMITH_TRACING="false"
LANGSMITH_API_KEY=""
LANGSMITH_PROJECT="ingenieria_soluciones_con_ia"

# --- URL interna del backend que usa el frontend (red docker) ---
BACKEND_URL="http://backend:8000"

# --- Dirección del sitio para Caddy (el Caddyfile usa 'tls internal') ---
# El Caddyfile emite un certificado self-signed con la CA interna de Caddy, así
# que el navegador mostrará un aviso (normal en este curso).
#   - Local:        SITE_ADDRESS=localhost   (abre https://localhost)
#   - EC2 por IP:   SITE_ADDRESS=https://TU_IP_PUBLICA   (p. ej. https://203.0.113.10)
#                   Necesario para que Caddy emita el cert para ESA IP y sirva HTTPS.
#   - Dominio real: SITE_ADDRESS=tudominio.com  y QUITA 'tls internal' del Caddyfile
#                   para obtener un certificado válido (Let's Encrypt).
SITE_ADDRESS="localhost"

# --- Claves / Tokens para el agente y servicios ---
OPENAI_API_KEY=""

# --- SMTP (opcional) ---
SENDER_EMAIL=""
SENDER_PASSWORD=""

# --- Alert thresholds (opcional) ---
P95_THRESHOLD_S=2.0
ERROR_RATE_THRESHOLD=0.05
ALERT_CHECK_INTERVAL_S=60
