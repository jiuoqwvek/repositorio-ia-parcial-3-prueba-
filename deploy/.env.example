# .env example for deploy/ (copy this to .env inside deploy/ and edit)
# SITE_ADDRESS must include scheme, e.g. https://<IP_PUBLICA> or https://your.domain
SITE_ADDRESS=

# API keys / tokens
OPENAI_API_KEY=
GITHUB_TOKEN=

# Optional SMTP settings for enviar_correo
SENDER_EMAIL=
SENDER_PASSWORD=

# Alert thresholds
P95_THRESHOLD_S=2.0
ERROR_RATE_THRESHOLD=0.05
ALERT_CHECK_INTERVAL_S=60
